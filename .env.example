TELEGRAM_BOT_TOKEN=123456:replace_me

# Avito API application credentials from https://developers.avito.ru/
AVITO_CLIENT_ID=replace_me
AVITO_CLIENT_SECRET=replace_me

# Optional. If empty, the bot tries to request the current account id from Avito.
AVITO_USER_ID=

# Polling interval in seconds. 10 is a balanced default for a small private bot.
POLL_INTERVAL_SECONDS=10

# Window for combining messages from the same chat in one notification.
GROUP_WINDOW_SECONDS=10

# Diagnostic logs. Enable temporarily while debugging Avito responses.
AVITO_LOG_RESPONSES=false
AVITO_DEBUG_FETCH_ALL_CHATS=false

# Directory with users.txt, invites.txt and processed_messages.txt.
DATA_DIR=./data
